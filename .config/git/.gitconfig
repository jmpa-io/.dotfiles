[user]
  # No identity committed here - set name and email locally per machine.
  # For work machines, create ~/.gitconfig-work with your work identity:
  #
  #   [user]
  #     name = Your Name
  #     email = your.email@work.com
  #
  # The [includeIf] blocks below will pick it up automatically for repos
  # inside the configured work directories.

# Work identity — CBA repos.
[includeIf "gitdir:~/go/src/github.com/CBA-General/"]
  path = ~/.gitconfig-work
[includeIf "gitdir:~/go/src/github.com/CBA-GroupSecurity-RSTD/"]
  path = ~/.gitconfig-work
[includeIf "gitdir:~/go/src/github.com/CBA-QTN-PublicCloudLZExceptions/"]
  path = ~/.gitconfig-work

# Personal identity — personal repos and dotfiles.
[includeIf "gitdir:~/go/src/github.com/jcleal/"]
  path = ~/.gitconfig-personal
[includeIf "gitdir:~/go/src/github.com/jmpa-io/"]
  path = ~/.gitconfig-personal
[includeIf "gitdir:~/.dotfiles/"]
  path = ~/.gitconfig-personal
[includeIf "gitdir:~/.dotfiles/.config/neovim/"]
  path = ~/.gitconfig-personal

[safe]
  directory = /mnt/nfs/My_Music/downloading-music
  directory = ~/.dotfiles

[init]
  defaultBranch = main

[pull]
  rebase = true

[push]
  default = current

[color]
  ui = true

# force https, instead of ssh, for things like 'go get'.
[url "https://github.com/"]
  insteadOf = "git@github.com:"

# use gh as a cred helper.
[credential "https://github.com/"]
  helper = !gh auth git-credential
[credential "https://gist.github.com"]
  helper = !gh auth git-credential

[alias]
  # makes it easier to determine if the branch is main or master.
  # taken from: https://stackoverflow.com/questions/66232497/git-alias-which-works-for-main-or-master-or-other/67672350#67672350
  main-branch = !git symbolic-ref refs/remotes/origin/HEAD | cut -d'/' -f4

[diff]
  colormoved = "default"
  colormovedws = "allow-indentation-change"
