{
  "$schema": "https://opencode.ai/config.json",
  "share": "disabled",
  "mcp": {
    "context7": {
      "type": "remote",
      "url": "https://mcp.context7.com/mcp",
      "enabled": true,
      "timeout": 600000
    },
    "sequentialthinking": {
      "type": "local",
      "command": ["npx", "--yes", "@modelcontextprotocol/server-sequential-thinking"],
      "timeout": 600000
    },
    "playwright": {
      "type": "local",
      "command": ["npx", "--yes", "@playwright/mcp@latest"],
      "timeout": 600000
    },
    "chrome-devtools": {
      "type": "local",
      "command": ["npx", "--yes", "chrome-devtools-mcp@latest"],
      "timeout": 600000
    },
    "browser-manager": {
      "type": "local",
      "command": ["{env:HOME}/go/bin/browser-manager", "mcp"],
      "enabled": true,
      "timeout": 60000
    },
    "email_manager": {
      "type": "local",
      "command": ["{env:HOME}/go/src/github.com/jmpa-io/email-manager/email-manager"],
      "enabled": true,
      "timeout": 60000
    },
    "pocketsmith": {
      "type": "local",
      "command": ["{env:HOME}/go/src/github.com/jmpa-io/pocketsmith-mcp/dist/pocketsmith-mcp"],
      "enabled": true,
      "timeout": 60000,
      "environment": {
        "POCKETSMITH_TOKEN": "{env:POCKETSMITH_TOKEN}",
        "POCKETSMITH_SESSION": "{env:POCKETSMITH_SESSION}"
      }
    },
    "up": {
      "type": "local",
      "command": ["{env:HOME}/go/src/github.com/jmpa-io/up-mcp/dist/up-mcp"],
      "enabled": true,
      "timeout": 60000,
      "environment": {
        "UP_TOKEN": "{env:UP_TOKEN}"
      }
    },
    "gdrive": {
      "type": "local",
      "command": ["npx", "--yes", "@modelcontextprotocol/server-gdrive"],
      "enabled": true,
      "timeout": 60000,
      "environment": {
        "GDRIVE_OAUTH_PATH": "{env:HOME}/.config/gcloud/client_secret.json",
        "GDRIVE_CREDENTIALS_PATH": "{env:HOME}/.config/gcloud/gdrivetoken.json"
      }
    }
  }
}
