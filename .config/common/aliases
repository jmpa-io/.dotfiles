#!/usr/bin/env bash
# handles aliases and extensions to commands for our terminal.

# funcs.
die() { echo "$1" >&2; exit "${2:-1}"; }

# $os is exported from .zshenv — no need to re-detect here.

# setup aliases to autojump to previously visited directories.
alias d="dirs -v"
for index in {0..9}; do alias "$index"="cd +${index}"; done; unset index

# zsh.
alias zsrc='for f in "$HOME/aliases" "$HOME/.zshenv" "$HOME/.zshrc" "$HOME/work"; do [[ -f "$f" ]] && source "$f"; done'

# Broadcast 'source ~/work' to all panes in the current tmux session.
# Use after key rotation so all shells pick up the new PORTKEY_API_KEY immediately.
alias b-src='tmux list-panes -a -F "#{pane_id}" | xargs -I{} tmux send-keys -t {} "source $HOME/work" Enter'

# tmux sessions — each creates or attaches to a named session with a fixed layout.
# Use across multiple screens — attach from any window with the same alias.

# work: 2x2 grid (4 panes) — CBA work session
s-work() {
  tmux new-session -d -s work 2>/dev/null
  tmux split-window -h -t work
  tmux split-window -v -t work:1.1
  tmux split-window -v -t work:1.2
  tmux select-pane -t work:1.1
  tmux attach-session -t work
}

# homelab: main left + 2 stacked right (3 panes)
s-homelab() {
  tmux new-session -d -s homelab 2>/dev/null
  tmux split-window -h -t homelab
  tmux split-window -v -t homelab:1.2
  tmux select-pane -t homelab:1.1
  tmux attach-session -t homelab
}

# misc: single pane — clean shell for one-offs
s-misc() { tmux new-session -A -s misc; }

# email.
alias sort-mail='bash "$DOTFILES/.config/common/bin/sort-mail.sh"'

# general.
case "$os" in
  Darwin)
    alias ls='ls -G'
    alias dotfiles='code "$DOTFILES"'
    alias code='open -a "Visual Studio Code"'
    alias grep="grep --color=auto"
    alias act="act --container-architecture linux/amd64"
  ;;
  Linux)
    alias ls='ls --color=auto'                                          # overrides ls to run this default.
    alias dotfiles="nvim \"+cd $DOTFILES\" $DOTFILES"                   # opens dotfiles in IDE.
    alias grep="grep --color=auto"                                      # overrides grep to run this default.
    alias lock="$HOME/bin/system/lock.sh"                               # locks the computer.
    alias lockscreen="$HOME/bin/system/lock.sh"                         # verbose alias for lock.
    alias shutdown="shutdown -h now"                                    # shuts down the computer immediately.
    alias restart="shutdown -r now"                                     # restarts the computer immediately.
    alias screenshot="scrot"                                            # takes a screenshot.
    alias orphans="pacman -Qtdq | sudo pacman -Rns -"                   # removes all orphaned packages.
    alias clock="tty-clock -s -c -C 5 -t"                               # renders a nice clock, using tty-clock, in the terminal.
    alias neofetch="fastfetch"                                          # prints system information.
    alias open="pcmanfm"                                                # opens the given directory in a GUI file manager.
  ;;
esac

# opens the last screenshot taken in Firefox (resolved at invocation time, not source time).
olss() {
  local f
  f=$(ls -1t "$HOME/Pictures" | head -n1)
  [[ -n "$f" ]] && firefox "$HOME/Pictures/$f"
}

# Writes the active AWS_PROFILE to ~/work so it persists across new terminals.
# Only writes if ~/work exists — no-op otherwise.
_aws_write_profile_to_work() {
  local profile="$1"
  local work="$HOME/work"
  [[ -f "$work" ]] || return 0
  # Replace existing AWS_PROFILE line or append if not present.
  if grep -q "^export AWS_PROFILE=" "$work"; then
    if [[ "$OSTYPE" == "darwin"* ]]; then
      sed -i '' "s|^export AWS_PROFILE=.*|export AWS_PROFILE=\"$profile\"|" "$work"
    else
      sed -i "s|^export AWS_PROFILE=.*|export AWS_PROFILE=\"$profile\"|" "$work"
    fi
  else
    echo "export AWS_PROFILE=\"$profile\"" >> "$work"
  fi
}

# aws overrides.
aws() {
  case $* in

    # what is the AWS IAM Role I am authed to?
    auth)
      command aws sts get-caller-identity ;;

    # what is the ARN of the AWS IAM Role I am authed as?
    who)
      command aws sts get-caller-identity --query "Arn" --output text ;;

    # list ALL the AWS profiles available, including which one is currently authed.
    profiles)
      profile="${AWS_PROFILE:-default}"
      command aws --no-cli-pager configure list-profiles | while read p; do
        # Skip -admin profiles as they're just for role assumption.
        [[ "$p" == *-admin ]] && continue
        # Show * for both the profile and its -admin variant
        prefix="  "
        [[ "$p" == "$profile" || "${p}-admin" == "$profile" ]] && prefix=" *"
        echo "$prefix $p"
      done
      ;;

     # resets the AWS_PROFILE to the default profile.
    "profile clear")
      export AWS_PROFILE="default"
      _aws_write_profile_to_work "default"
      ;;

    # logs into the AWS Account associated with the given profile.
    # supports --no-browser flag for remote/headless login (prints URL instead of opening browser).
    "login "*)
      profile="$2"
      no_browser=0
      [[ "$*" == *"--no-browser"* ]] && no_browser=1

      if ! command aws --no-cli-pager configure list-profiles | grep -q "^${profile}$"; then
        echo "'$profile' is not a valid AWS profile; Run 'aws profiles' to see a list of profiles."
        return 1
      fi

      if [[ "$no_browser" == 1 ]]; then
        command aws sso login --profile "$profile" --no-browser
      else
        command aws sso login --profile "$profile"
      fi

      # Check if there's a corresponding -admin profile and use that instead
      admin_profile="${profile}-admin"
      if command aws --no-cli-pager configure list-profiles | grep -q "^${admin_profile}$"; then
        export AWS_PROFILE="$admin_profile"
        _aws_write_profile_to_work "$admin_profile"
        echo "Switched to admin profile: $admin_profile"
      else
        export AWS_PROFILE="$profile"
        _aws_write_profile_to_work "$profile"
        echo "Using profile: $profile"
      fi
      ;;

    # a quick way to auth to the given AWS ECR repository, using the ARN.
    "ecr "*.dkr.ecr.*.amazonaws.com*)
      command aws ecr get-login-password --region ap-southeast-2 | docker login --username AWS --password-stdin "$2" ;;

    # run the default command, if none of the above are applicable.
    *)
      command aws "$@" ;;
  esac
}

# git overrides.
git() {
  case $* in

    # checks who the current gh user is, and what git identity will be used for commits.
    "who")
      local gh_user gh_protocol name email name_src email_src y r
      y=$'\033[1;33m'
      r=$'\033[0m'
      gh_user=$(command gh auth status --active --json hosts --jq '.hosts."github.com"[0].login' 2>/dev/null || echo "(not logged in)")
      gh_protocol=$(command gh auth status --active --json hosts --jq '.hosts."github.com"[0].gitProtocol' 2>/dev/null || echo "(unknown)")
      name=$(command git config user.name 2>/dev/null || echo "(not set)")
      email=$(command git config user.email 2>/dev/null || echo "(not set)")
      name_src=$(command git config --show-origin user.name 2>/dev/null | cut -f1 | sed 's|file:||' | sed "s|$HOME|~|" || echo "(not set)")
      email_src=$(command git config --show-origin user.email 2>/dev/null | cut -f1 | sed 's|file:||' | sed "s|$HOME|~|" || echo "(not set)")
      printf "\n"
      printf "  gh auth (cli)      %s  (${y}%s${r})\n" "$gh_user" "$gh_protocol"
      printf "  commit author      %s  (${y}%s${r})\n" "$name" "$name_src"
      printf "  commit email       %s  (${y}%s${r})\n" "$email" "$email_src"
      printf "\n"
      ;;

    "switch")
      command gh auth switch
      case "$os" in
        Darwin)
          git credential-osxkeychain erase <<< "protocol=https
host=github.com" 2>/dev/null || true
          ;;
        Linux)
          git credential reject <<< "protocol=https
host=github.com" 2>/dev/null || true
          ;;
      esac
      ;;

    # runs 'git pull' while pruning old branches.
    "pull "*)
      command git pull --prune "${@:2}" ;;

    # runs 'git clone' and then changes into the directory cloned.
    "clone "*)
      local args=("${@:2}")
      local dest="${args[-1]}"
      # derive dir name from URL (handles extra flags like --depth 1).
      [[ "$dest" == *"://"* || "$dest" == *"@"* ]] && dest="$(basename "$dest" .git)"
      command git clone "${args[@]}" && cd "$dest" ;;

    # shows all the branches available.
    branch)
      command git branch --all ;;

    # opens the repository in the default browser.
    "open")
      url=$(command git remote get-url origin \
        | sed -E 's|git@github\.com:|https://github.com/|' \
        | sed -E 's|\.git$||')
      case "$os" in
        Darwin)
          open "$url"
          ;;
        Linux)
          xdg-open "$url"
          ;;
      esac
      ;;

    # run the default command, if none of the above are applicable.
    *)
      command git "$@" ;;
  esac
}
